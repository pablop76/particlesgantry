{% endif %}
{% if sticky_class == 'sticky-top' or sticky_class == 'scroll-up' %}
#{{ id }}-particle.navbar-is-sticky {
    position: fixed; top: 0; left: 0; width: 100%; z-index: 1030;
    background-color: {{ _s_bg ?: '#ffffff' }};
{% if nav_shadow %}    box-shadow: 0 2px 6px rgba(0,0,0,.12);{% endif %}
}
{% if sticky_class == 'scroll-up' %}
#{{ id }}-particle.navbar-is-sticky { transition: transform 0.3s ease; }
#{{ id }}-particle.navbar-is-sticky.navbar-hidden { transform: translateY(-100%); }
#{{ id }}-particle.navbar-no-transition,
#{{ id }}-particle.navbar-no-transition * { transition: none !important; }
{% endif %}
{% endif %}
{% if r_scroll_bg %}
{% if sticky_class != 'scroll-up' %}
#{{ id }}-particle.navbar-is-sticky { transition: background-color 0.3s ease; }
{% endif %}
#{{ id }}-particle.navbar-is-sticky.navbar-scrolled { background-color: {{ r_scroll_bg|e }}; }
{% endif %}
{% if logo_shrink %}
#{{ id }}-particle .navbar-brand img { transition: max-height 0.3s ease; }
#{{ id }}-particle.navbar-scrolled .navbar-brand img { max-height: {{ logo_shrink_h|e }} !important; }
{% endif %}
{% if nav_constrained %}
#{{ id }}-particle .container-fluid { max-width: {{ bp_ld|e }}; }
@media (max-width: {{ bp_ld|e }}) { #{{ id }}-particle .container-fluid { max-width: {{ bp_d|e }}; } }
@media (max-width: {{ bp_d|e }})  { #{{ id }}-particle .container-fluid { max-width: {{ bp_t|e }}; } }
@media (max-width: {{ bp_t|e }})  { #{{ id }}-particle .container-fluid { max-width: {{ bp_m|e }}; } }
@media (max-width: {{ bp_m|e }})  { #{{ id }}-particle .container-fluid { max-width: 100%; } }
{% endif %}
</style>
{% endif %}
{% endblock %}

{# ============================================================
   JS
   ============================================================ #}
{% block javascript_footer %}
{% if particle.enabled %}
<script>
(function () {
    var root = (typeof Joomla !== 'undefined' && Joomla.getOptions)
        ? (Joomla.getOptions('system.paths') || {}).root || ''
        : '';

    var base = root + '/media/vendor/bootstrap/js/';
    /* Tylko 3 potrzebne komponenty: offcanvas, dropdown (z Popper), collapse */
    /* data-bs-* atrybuty działają automatycznie po załadowaniu modułów */
    import(base + 'offcanvas.min.js');
    import(base + 'dropdown.min.js');
    import(base + 'collapse.min.js');
}());
{% if sticky_class == 'sticky-top' or sticky_class == 'scroll-up' or logo_shrink %}
(function () {
    var nav = document.getElementById('{{ id }}-particle');
    if (!nav) return;
    var bpMap = { sm: 576, md: 768, lg: 992, xl: 1200, xxl: 1400 };
    var expandAt = bpMap['{{ expand_bp }}'] || 992;
    function isDesktop() { return window.innerWidth >= expandAt; }
    function reset() {
        nav.classList.remove('navbar-is-sticky', 'navbar-hidden', 'navbar-scrolled');
        if (ph) ph.style.display = 'none';
    }
    var ph = null;
    {% if sticky_class == 'sticky-top' or sticky_class == 'scroll-up' %}
    ph = document.createElement('div');
    ph.setAttribute('aria-hidden', 'true');
    ph.style.display = 'none';
    nav.parentNode.insertBefore(ph, nav);
    {% endif %}

    {% if sticky_class == 'sticky-top' %}
    var navTop = 0;
    function recalc() {
        if (!nav.classList.contains('navbar-is-sticky')) {
            navTop = nav.getBoundingClientRect().top + window.pageYOffset;
        }
        ph.style.height = nav.offsetHeight + 'px';
    }
    function update() {
        if (!isDesktop()) { reset(); return; }
        var y = window.pageYOffset;
        var stuck = y >= navTop;
        if (stuck !== nav.classList.contains('navbar-is-sticky')) {
            nav.classList.toggle('navbar-is-sticky', stuck);
            ph.style.display = stuck ? 'block' : 'none';
        }
        nav.classList.toggle('navbar-scrolled', stuck);
    }
    window.addEventListener('resize', function() { recalc(); update(); }, { passive: true });
    window.addEventListener('load',   function() { recalc(); update(); }, { passive: true });
    recalc(); update();
    {% endif %}

    {% if sticky_class == 'scroll-up' %}
    var lastY = window.pageYOffset;
    function recalc() { ph.style.height = nav.offsetHeight + 'px'; }
    function update() {
        if (!isDesktop()) { reset(); return; }
        var y     = window.pageYOffset;
        var delta = y - lastY;
        if (Math.abs(delta) < 5) return;
        lastY = y;
        if (y > 80) {
            var hiding = delta > 0;
            /* navbar-scrolled i navbar-hidden ustawiane razem —
               background-color i transform startują w tym samym event loop  */
            nav.classList.toggle('navbar-scrolled', true);
            nav.classList.toggle('navbar-hidden', hiding);
        } else {
            /* y <= 80: usuń oba naraz (tło i pozycja wracają razem)          */
            nav.classList.remove('navbar-hidden', 'navbar-scrolled');
        }
    }
    function initScrollUp() {
        if (!isDesktop()) return;
        /* Wyłącz transition, ustaw stan, poczekaj DWA rAF (= przeglądarka
           musi wyrenderować 1 klatkę) zanim włączysz transition z powrotem  */
        nav.classList.add('navbar-no-transition');
        nav.classList.add('navbar-is-sticky');
        nav.classList.toggle('navbar-scrolled', window.pageYOffset > 80);
        ph.style.display = 'block';
        recalc();
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                nav.classList.remove('navbar-no-transition');
            });
        });
    }
    /* ResizeObserver śledzi rzeczywistą wysokość nav w czasie rzeczywistym —
       aktualizuje placeholder frame-by-frame podczas CSS transition logo     */
    if (window.ResizeObserver) {
        new ResizeObserver(recalc).observe(nav);
    }
    window.addEventListener('resize', function() { isDesktop() ? initScrollUp() : reset(); }, { passive: true });
    window.addEventListener('load',   function() { initScrollUp(); }, { passive: true });
    initScrollUp(); update();
    {% endif %}

    {% if logo_shrink and sticky_class != 'sticky-top' and sticky_class != 'scroll-up' %}
    function update() {
        if (!isDesktop()) { nav.classList.remove('navbar-scrolled'); return; }
        nav.classList.toggle('navbar-scrolled', window.pageYOffset > 80);
    }
    update();
    {% endif %}

    window.addEventListener('scroll', update, { passive: true });
}());
{% endif %}
</script>
{% endif %}
{% endblock %}

{% block particle %}
{% if particle.enabled %}

{# Ładowanie menu — {% try %} MUSI być wewnątrz bloku #}
{% try %}
    {% set menu = gantry.menu.instance(particle) %}
{% catch %}
    <div class="alert alert-danger" role="alert">{{ e.getMessage }}</div>
{% endtry %}

{# ---------- Navbar desktop ---------- #}
<nav id="{{ id }}-particle"
     class="navbar navbar-expand-{{ expand_bp }} align-items-stretch{% if sticky_class == 'fixed-top' %} fixed-top{% endif %}{% if particle.class %} {{ particle.class }}{% endif %}"
     aria-label="Nawigacja główna">
    <div class="container-fluid">

        {# Logo / Brand #}
        {% if has_logo %}
        <a class="navbar-brand"
           href="{{ logo_url }}"
           {% if logo_url == gantry.siteUrl() %}rel="home"{% endif %}
           {% if particle.logo_text %}aria-label="{{ particle.logo_text|striptags|e }}"{% endif %}>
            {% if particle.logo_image and particle.mobile_logo_image %}
                {# Dwa loga: główne na desktop, mobilne poniżej breakpointu #}
                <img src="{{ url(particle.logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     class="d-none d-{{ expand_bp }}-block"
                     fetchpriority="high"
                     decoding="async"
                     {% if particle.logo_height %}style="max-height:{{ particle.logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
                <img src="{{ url(particle.mobile_logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     class="d-{{ expand_bp }}-none"
                     fetchpriority="high"
                     decoding="async"
                     {% if particle.mobile_logo_height %}style="max-height:{{ particle.mobile_logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
            {% elseif particle.mobile_logo_image %}
                <img src="{{ url(particle.mobile_logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     fetchpriority="high"
                     decoding="async"
                     {% if particle.mobile_logo_height %}style="max-height:{{ particle.mobile_logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
            {% elseif particle.logo_image %}
                <img src="{{ url(particle.logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     fetchpriority="high"
                     decoding="async"
                     {% if particle.logo_height %}style="max-height:{{ particle.logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
            {% else %}
                {{ particle.logo_text|raw }}
            {% endif %}
        </a>
        {% endif %}

        {# Hamburger → otwiera offcanvas na mobile #}
        <button type="button"
                class="navbar-toggler"
                data-bs-toggle="offcanvas"
                data-bs-target="#{{ offcanvas_id }}"
                aria-controls="{{ offcanvas_id }}"
                aria-expanded="false"
                aria-label="Otwórz menu">
            {% if particle.toggle_image %}
                <img src="{{ url(particle.toggle_image)|e }}"
                     alt=""
                     role="presentation"
                     decoding="async"
                     style="height:{{ particle.toggle_image_height|default('24px') }};width:auto;display:block;">
            {% elseif particle.toggle_icon %}
                <span class="{{ particle.toggle_icon|e }}" aria-hidden="true"></span>
            {% else %}
                <span class="navbar-toggler-icon" aria-hidden="true"></span>
            {% endif %}
            {% if particle.toggle_text %}
                <span class="ms-1">{{ particle.toggle_text }}</span>
            {% endif %}
        </button>

        {# Desktop nav (widoczna ≥ expand_bp, ukryta na mobile przez Bootstrap) #}
        {% if menu is defined and menu.root.count() %}
        <div class="collapse navbar-collapse align-items-stretch">
            <ul class="navbar-nav {{ nav_margin }}">
                {{ macro.desktopItems(menu.root, menu, _context) }}
            </ul>
            {% if social_items|length and particle.social_in_navbar|default(true) %}
            <ul class="navbar-nav ms-3 flex-row gap-1 g-nav-social" aria-label="Social media">
                {% for s in social_items %}
                {% set s_icon = s.icon|default('') %}
                {% if s.url and s_icon and s.label %}
                <li class="nav-item">
                    <a class="nav-link px-1"
                       href="{{ s.url|e }}"
                       aria-label="{{ s.label|e }}"
                       {% if s.target_blank|default(true) %}target="_blank" rel="noopener noreferrer"{% endif %}>
                        <span class="{{ s_icon|e }}" aria-hidden="true"></span>
                    </a>
                </li>
                {% endif %}
                {% endfor %}
            </ul>
            {% endif %}
        </div>
        {% endif %}

    </div>
</nav>

{# ---------- Offcanvas (mobile) ---------- #}
<div class="offcanvas offcanvas-{{ oc_side }}"
     id="{{ offcanvas_id }}"
     tabindex="-1"
     data-bs-theme="{{ particle.offcanvas_color_scheme|default('light') }}"
     aria-labelledby="{{ offcanvas_id }}-label">

    <div class="offcanvas-header">

        {# Ukryty tytuł wymagany przez Bootstrap a11y: aria-labelledby musi wskazywać
           na element z offcanvas-title. Logo jest treścią wizualną, nie tytułem dialogu. #}
        <h2 id="{{ offcanvas_id }}-label" class="offcanvas-title visually-hidden">Menu nawigacyjne</h2>

        {% if particle.offcanvas_show_logo|default(true) and has_logo %}
        <a class="navbar-brand"
           href="{{ logo_url }}"
           {% if logo_url == gantry.siteUrl() %}rel="home"{% endif %}
           aria-label="{{ particle.logo_text ? particle.logo_text|striptags|e : 'Strona główna' }}">
            {% if particle.mobile_logo_image %}
                <img src="{{ url(particle.mobile_logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     decoding="async"
                     {% if particle.mobile_logo_height %}style="max-height:{{ particle.mobile_logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
            {% elseif particle.logo_image %}
                <img src="{{ url(particle.logo_image)|e }}"
                     alt="{{ particle.logo_text|default('Logo') }}"
                     decoding="async"
                     {% if particle.logo_height %}style="max-height:{{ particle.logo_height }};width:auto"{% else %}style="height:auto;width:auto"{% endif %}>
            {% else %}
                {{ particle.logo_text|raw }}
            {% endif %}
        </a>
        {% endif %}

        {% if particle.offcanvas_close_icon %}
        <button type="button" class="btn btn-link p-0 ms-auto oc-close-btn" data-bs-dismiss="offcanvas" aria-label="Zamknij menu" style="color:inherit">
            <span class="{{ particle.offcanvas_close_icon|e }}" aria-hidden="true"></span>
        </button>
        {% else %}
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="offcanvas" aria-label="Zamknij menu"></button>
        {% endif %}
    </div>

    <div class="offcanvas-body d-flex flex-column">
        {% if menu is defined and menu.root.count() %}
        <ul class="nav flex-column">
            {{ macro.mobileItems(menu.root, menu, _context) }}
        </ul>
        {% endif %}
        {% if social_items|length and particle.social_in_offcanvas|default(true) %}
        <ul class="nav flex-row flex-wrap gap-2 mt-auto pt-3 g-nav-social" aria-label="Social media">
            {% for s in social_items %}
            {% set s_icon = s.icon|default('') %}
            {% if s.url and s_icon and s.label %}
            <li class="nav-item">
                <a class="nav-link px-1"
                   href="{{ s.url|e }}"
                   aria-label="{{ s.label|e }}"
                   {% if s.target_blank|default(true) %}target="_blank" rel="noopener noreferrer"{% endif %}>
                    <span class="{{ s_icon|e }}" aria-hidden="true"></span>
                </a>
            </li>
            {% endif %}
            {% endfor %}
        </ul>
        {% endif %}
    </div>

</div>

{% endif %}
{% endblock %}
