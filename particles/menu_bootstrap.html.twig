{% if r_oc_bg %}    background-color: {{ r_oc_bg|e }};
{% endif %}
{% if _oc_width %}    --bs-offcanvas-width: {{ _oc_width|e }};
{% endif %}
}
{% endif %}
{% if r_oc_font_size %}
#{{ offcanvas_id }} .nav-link { font-size: {{ r_oc_font_size|e }}; }
{% endif %}
{% if _oc_color %}
#{{ offcanvas_id }} .nav-link,
#{{ offcanvas_id }} .navbar-brand,
