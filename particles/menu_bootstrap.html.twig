{% extends '@nucleus/partials/particle.html.twig' %}

{# ============================================================
   Zmienne globalne — {% set %} poza blokami jest OK w extends,
   {% try %} NIE jest (może produkować output) — menu ładujemy
   wewnątrz {% block particle %}.
   ============================================================ #}
{% set expand_bp    = particle.expand_bp|default('lg') %}
{% set offcanvas_id = 'bs-nav-' ~ id %}
{% set oc_side      = particle.offcanvas_side|default('start') %}
{% set logo_url     = url(particle.logo_url)|default(gantry.siteUrl()) %}
{% set has_logo     = particle.logo_image or particle.logo_text or particle.mobile_logo_image %}
{% set sticky_class      = particle.sticky|default('') %}
{% set nav_shadow        = particle.nav_shadow|default(false) %}
{% set logo_shrink       = particle.logo_shrink|default(false) %}
{% set logo_shrink_h     = particle.logo_shrink_height|default('30px') %}
{% set social_items   = particle.social_items|default([]) %}
{% set r_social_color = particle.social_color|default('') %}
{% set nav_align     = particle.nav_align|default('end') %}
{% set nav_margin    = nav_align == 'start' ? 'me-auto' : (nav_align == 'center' ? 'mx-auto' : 'ms-auto') %}
{% set nav_constrained = particle.nav_container|default('fluid') == 'gantry' %}
{# Breakpointy z Gantry config — używane tylko gdy nav_constrained = true #}
{% set bp_ld = gantry.config.get('styles.breakpoints.large-desktop-container')|default('75rem') %}
{% set bp_d  = gantry.config.get('styles.breakpoints.desktop-container')|default('60rem') %}
{% set bp_t  = gantry.config.get('styles.breakpoints.tablet-container')|default('48rem') %}
{% set bp_m  = gantry.config.get('styles.breakpoints.large-mobile-container')|default('30rem') %}
{# --- Kolory: styl szablonu jako default, particle admin jako override --- #}
{% set _s_color      = gantry.config.get('styles.navigation.text-color')|default('') %}
{% set _s_bg         = gantry.config.get('styles.navigation.background')|default('') %}
{% set _accent2      = gantry.config.get('styles.accent.color-2')|default('#8f4dae') %}
{# Offcanvas Styles z konfiguracji szablonu (Styles → Offcanvas Styles) #}
{% set _oc_bg        = gantry.config.get('styles.offcanvas.background')|default('') %}
{% set _oc_color     = gantry.config.get('styles.offcanvas.text-color')|default('') %}
{% set _oc_width     = gantry.config.get('styles.offcanvas.width')|default('') %}
{% set r_color       = particle.nav_color       ?: _s_color %}
{% set r_hover_color = particle.nav_hover_color ?: _s_color %}
{% set r_scroll_bg   = particle.scroll_bg|default('') %}
{% set r_dropdown_bg = particle.dropdown_bg     ?: '' %}
{% set r_oc_bg        = particle.offcanvas_bg    ?: _oc_bg %}
{% set r_oc_font_size = particle.offcanvas_font_size|default('') %}
{# --- Typografia --- #}
{# input.fonts zapisuje jako: Bad+Script&subset=cyrillic,latin; lub family=Bad+Script&subset=... #}
{% set _font_raw     = particle.nav_font_family|default('')|replace({';': ''})|trim %}
{% set r_font_family = '' %}
{% set r_font_gurl   = '' %}
{% if _font_raw %}
    {# Usuń ewentualny prefix family= #}
    {% set _font_qs = _font_raw|replace({'family=': ''}) %}
    {# Nazwa fontu = część przed pierwszym & lub całość, zamień + na spację #}
    {% set _font_name = _font_qs|split('&')|first|replace({'+': ' '})|trim %}
    {% set r_font_family = "'" ~ _font_name ~ "', sans-serif" %}
    {% set r_font_gurl   = 'https://fonts.googleapis.com/css?' ~ (_font_raw starts with 'family=' ? '' : 'family=') ~ _font_raw ~ '&display=swap' %}
{% endif %}
{% set r_font_size      = particle.nav_font_size|default('') %}
{% set r_font_weight    = particle.nav_font_weight|default('') %}
{% set r_text_transform = particle.nav_text_transform|default('') %}
{% set r_letter_spacing = particle.nav_letter_spacing|default('') %}
{% set r_item_gap       = particle.nav_item_gap|default('') %}
{% set r_link_px        = particle.nav_link_padding_x|default('') %}
{% set r_link_py        = particle.nav_link_padding_y|default('') %}
{% set r_dd_font_size   = particle.dropdown_font_size|default('') %}
{% set r_dd_item_py     = particle.dropdown_item_padding_y|default('') %}
{% set r_dd_hover_bg    = particle.dropdown_hover_bg|default('') %}
{% set r_dd_hover_color = particle.dropdown_hover_color|default('') %}


{# Makra i import — dozwolone poza blokami #}
{% import _self as macro %}

{# ============================================================
   MAKRA
   ============================================================ #}

{# ---------- displayTitle: tytuł + opcjonalny podtytuł ---------- #}
{% macro displayTitle(item) %}
    {% if not item.icon_only or not (item.image or item.icon) %}
        {% if item.subtitle %}
            <span>{{ item.title }}<small class="d-block opacity-75 fw-normal lh-1">{{ item.subtitle }}</small></span>
        {% else %}
            {{- item.title -}}
        {% endif %}
    {% endif %}
{% endmacro %}

{# ---------- linkAttrs: wspólne atrybuty dla każdego <a> ---------- #}
{% macro linkAttrs(item, context) %}
    {%- if item.anchor_class %} class="{{ item.anchor_class }}"{% endif %}
    {%- if item.icon_only or item.link_title %} title="{{ (item.link_title|default(item.title))|e }}"{% endif %}
    {%- if item.icon_only and (item.image or item.icon) %} aria-label="{{ item.title|e }}"{% endif %}
    {%- if item.target != '_self' or context.particle.forceTarget %} target="{{ item.target|e }}"{% endif %}
{%- endmacro %}

{# ---------- linkContent: ikona/obrazek + tytuł ---------- #}
{# Obrazki menu mają loading="lazy" — mogą być poza widokiem (sticky, długie menu) #}
{% macro linkContent(item) %}
    {% import _self as self %}
    {% if item.image %}
        <img src="{{ url(item.image)|e }}"
             alt="{{ item.title|e }}"
             loading="lazy"
             decoding="async">
    {% elseif item.icon %}
        <span class="{{ item.icon|e }}" aria-hidden="true"></span>
    {% endif %}
    {{- self.displayTitle(item) -}}
{% endmacro %}

{% macro desktopItem(item, menu, context) %}
    {% import _self as self %}
    {% if item.type == 'particle' and not item.options.particle.enabled %}{% set enabled = 0 %}{% endif %}
    {% if item.visible and item.enabled and enabled|default(1) %}

        {% if item.type == 'separator' or (item.type == 'heading' and not item.url) %}
            {# separator i nagłówek bez URL w poziomym navbar — pomijamy (jak natywna cząstka Gantry) #}

        {% elseif item.children|length and not item.dropdown_hide|default(false) %}
            {% set active = menu.isActive(item) %}
            <li class="nav-item dropdown d-flex align-items-center{% if active %} active{% endif %}{% if item.class %} {{ item.class }}{% endif %}">
                {% if item.url %}
                    <a class="nav-link pe-1{% if active %} active{% endif %}"
                       href="{{ item.url ~ item.hash }}"
                       {% if active %}aria-current="page"{% endif %}
                       {{- self.linkAttrs(item, context)|raw }}>
                        {{ self.linkContent(item) }}
                    </a>
                    <button type="button"
                            class="nav-link px-1 dropdown-toggle dropdown-toggle-split border-0 bg-transparent"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            aria-label="Otwórz podmenu {{ item.title|e }}">
                        <span class="visually-hidden">Podmenu</span>
                    </button>
                {% else %}
                    <a class="nav-link dropdown-toggle{% if active %} active{% endif %}"
                       href="#"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-expanded="false"
                       {{- self.linkAttrs(item, context)|raw }}>
                        {{ self.linkContent(item) }}
                    </a>
                {% endif %}
                <ul class="dropdown-menu">
                    {{ self.desktopSubItems(item.children, menu, context) }}
                </ul>
            </li>

        {% else %}
            {% set active = menu.isActive(item) %}
            <li class="nav-item{% if active %} active{% endif %}{% if item.class %} {{ item.class }}{% endif %}">
                <a class="nav-link{% if active %} active{% endif %}"
                   href="{{ item.url ? item.url ~ item.hash : '#' }}"
                   {% if active %}aria-current="page"{% endif %}
                   {{- self.linkAttrs(item, context)|raw }}>
                    {{ self.linkContent(item) }}
                </a>
            </li>
        {% endif %}

    {% endif %}
{% endmacro %}

{% macro desktopItems(items, menu, context) %}
    {% import _self as self %}
    {% for item in items %}
        {{ self.desktopItem(item, menu, context) }}
    {% endfor %}
{% endmacro %}

{% macro desktopSubItems(items, menu, context) %}
    {% import _self as self %}
    {% for item in items %}
        {% if item.type == 'particle' and not item.options.particle.enabled %}{% set enabled = 0 %}{% endif %}
        {% if item.visible and item.enabled and enabled|default(1) %}

            {% if item.type == 'separator' %}
                <li><hr class="dropdown-divider"></li>

            {% elseif item.type == 'heading' and not item.url %}
                <li><h6 class="dropdown-header">{{ self.linkContent(item) }}</h6></li>

            {% elseif item.children|length and not item.dropdown_hide|default(false) %}
                {% set active = menu.isActive(item) %}
                <li class="dropdown-submenu{% if item.class %} {{ item.class }}{% endif %}">
                    <a class="dropdown-item dropdown-toggle{% if active %} active{% endif %}"
                       href="{{ item.url ? item.url ~ item.hash : '#' }}"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-expanded="false"
                       {{- self.linkAttrs(item, context)|raw }}>
                        {{ self.linkContent(item) }}
                    </a>
                    <ul class="dropdown-menu">
                        {{ self.desktopSubItems(item.children, menu, context) }}
                    </ul>
                </li>

            {% else %}
                {% set active = menu.isActive(item) %}
                <li class="{% if item.class %}{{ item.class }}{% endif %}">
                    <a class="dropdown-item{% if active %} active{% endif %}"
                       href="{{ item.url ? item.url ~ item.hash : '#' }}"
                       {% if active %}aria-current="page"{% endif %}
                       {{- self.linkAttrs(item, context)|raw }}>
                        {{ self.linkContent(item) }}
                    </a>
                </li>
            {% endif %}

        {% endif %}
    {% endfor %}
{% endmacro %}

{% macro mobileItems(items, menu, context, depth) %}
    {% import _self as self %}
    {% set depth = depth|default(0) %}
    {% for item in items %}
        {% if item.type == 'particle' and not item.options.particle.enabled %}{% set enabled = 0 %}{% endif %}
        {% if item.visible and item.enabled and enabled|default(1) %}

            {% if item.type == 'separator' %}
                <li class="nav-item"><hr class="my-1 opacity-25"></li>

            {% elseif item.type == 'heading' and not item.url %}
                <li class="nav-item">
                    <span class="nav-link fw-semibold text-muted small text-uppercase">
                        {{ self.linkContent(item) }}
                    </span>
                </li>

            {% elseif item.children|length and not item.dropdown_hide|default(false) %}
                {% set active  = menu.isActive(item) %}
                {% set coll_id = 'mobile-sub-' ~ item.id %}
                <li class="nav-item{% if item.class %} {{ item.class }}{% endif %}">
                    <div class="d-flex align-items-center">
                        {% if item.url %}
                            <a class="nav-link flex-grow-1{% if active %} active{% endif %}"
                               href="{{ item.url ~ item.hash }}"
                               {% if active %}aria-current="page"{% endif %}
                               {{- self.linkAttrs(item, context)|raw }}>
                                {{ self.linkContent(item) }}
                            </a>
                        {% else %}
                            <span class="nav-link flex-grow-1{% if active %} active{% endif %}">
                                {{ self.linkContent(item) }}
                            </span>
                        {% endif %}
                        <button type="button"
                                class="btn btn-link nav-link py-0 px-2"
                                data-bs-toggle="collapse"
                                data-bs-target="#{{ coll_id }}"
                                aria-expanded="{{ active ? 'true' : 'false' }}"
                                aria-controls="{{ coll_id }}"
                                aria-label="Otwórz podmenu {{ item.title|e }}">
                            <span class="fa fa-chevron-down" style="font-size:.75em" aria-hidden="true"></span>
                        </button>
                    </div>
                    <div id="{{ coll_id }}" class="collapse{% if active %} show{% endif %}">
                        <ul class="nav flex-column ps-3">
                            {{ self.mobileItems(item.children, menu, context, depth + 1) }}
                        </ul>
                    </div>
                </li>

            {% else %}
                {% set active = menu.isActive(item) %}
                <li class="nav-item{% if item.class %} {{ item.class }}{% endif %}">
                    <a class="nav-link{% if active %} active{% endif %}"
                       href="{{ item.url ? item.url ~ item.hash : '#' }}"
                       {% if active %}aria-current="page"{% endif %}
                       {{- self.linkAttrs(item, context)|raw }}>
                        {{ self.linkContent(item) }}
                    </a>
                </li>
            {% endif %}

        {% endif %}
    {% endfor %}
{% endmacro %}

{# ============================================================
   Style inline
   ============================================================ #}
{% block stylesheets %}
{% if particle.enabled %}
<script>(function(){if(document.head.querySelector('link[href*="bootstrap.min.css"]'))return;var l=document.createElement('link');l.rel='stylesheet';l.href='{{ gantry.siteUrl() }}media/vendor/bootstrap/css/bootstrap.min.css';document.currentScript.parentNode.insertBefore(l,document.currentScript);}());</script>
<style>
#{{ id }}-particle {
    --bs-navbar-color: {{ r_color ?: 'currentColor' }};
    --bs-navbar-hover-color: {{ r_hover_color ?: 'currentColor' }};
    --bs-navbar-active-color: {{ r_hover_color ?: 'currentColor' }};
    --bs-navbar-brand-color: {{ r_color ?: 'currentColor' }};
    --bs-navbar-brand-hover-color: {{ r_hover_color ?: 'currentColor' }};
    --bs-navbar-toggler-border-color: rgba(128,128,128,0.3);
{% if r_link_px %}    --bs-navbar-nav-link-padding-x: {{ r_link_px|e }};
{% endif %}
{% if r_dd_font_size %}    --bs-dropdown-font-size: {{ r_dd_font_size|e }};
{% endif %}
{% if r_dd_item_py %}    --bs-dropdown-item-padding-y: {{ r_dd_item_py|e }};
{% endif %}
}
{# font-family, font-weight, text-transform, letter-spacing — navbar + dropdown + offcanvas #}
{% set _has_global_typo = r_font_family or r_font_weight or r_text_transform or r_letter_spacing %}
{% if _has_global_typo %}
#{{ id }}-particle .nav-link,
#{{ id }}-particle .dropdown-item,
#{{ offcanvas_id }} .nav-link {
{% if r_font_family %}    font-family: {{ r_font_family|raw }};
{% endif %}
{% if r_font_weight %}    font-weight: {{ r_font_weight|e }};
{% endif %}
{% if r_text_transform %}    text-transform: {{ r_text_transform|e }};
{% endif %}
{% if r_letter_spacing %}    letter-spacing: {{ r_letter_spacing|e }};
{% endif %}
}
{% endif %}
{# font-size i padding-y — tylko górny poziom navbar (dropdown ma osobne ustawienia) #}
{% if r_font_size or r_link_py %}
#{{ id }}-particle .navbar-nav > .nav-item > .nav-link,
#{{ id }}-particle .navbar-nav > .nav-item > button.nav-link {
{% if r_font_size %}    font-size: {{ r_font_size|e }};
{% endif %}
{% if r_link_py %}    padding-top: {{ r_link_py|e }}; padding-bottom: {{ r_link_py|e }};
{% endif %}
}
{% endif %}
{% if r_item_gap %}
#{{ id }}-particle .navbar-nav { gap: {{ r_item_gap|e }}; }
{% endif %}
#{{ id }}-particle .navbar-nav:not(.g-nav-social) > .nav-item > .nav-link:not(.dropdown-toggle) {
    position: relative;
    text-decoration: none !important;
}
#{{ id }}-particle .navbar-nav:not(.g-nav-social) > .nav-item > .nav-link:not(.dropdown-toggle)::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    right: 50%;
    height: 2px;
    background: currentColor;
    transition: left 0.25s ease, right 0.25s ease;
}
#{{ id }}-particle .navbar-nav:not(.g-nav-social) > .nav-item > .nav-link:not(.dropdown-toggle):hover::after,
#{{ id }}-particle .navbar-nav:not(.g-nav-social) > .nav-item > .nav-link:not(.dropdown-toggle):focus::after,
#{{ id }}-particle .navbar-nav:not(.g-nav-social) > .nav-item > .nav-link:not(.dropdown-toggle).active::after {
    left: var(--bs-navbar-nav-link-padding-x, 0.5rem);
    right: var(--bs-navbar-nav-link-padding-x, 0.5rem);
}
{% set _dd_active_bg = r_dd_hover_bg ?: _accent2 %}
#{{ id }}-particle .dropdown-item {
    position: relative;
}
#{{ id }}-particle .dropdown-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: currentColor;
    transition: width 0.2s ease;
}
#{{ id }}-particle .dropdown-item.active,
#{{ id }}-particle .dropdown-item:hover,
#{{ id }}-particle .dropdown-item:focus {
    background-color: {{ _dd_active_bg|e }} !important;
}
#{{ id }}-particle .dropdown-item.active::before,
#{{ id }}-particle .dropdown-item:hover::before,
#{{ id }}-particle .dropdown-item:focus::before {
    width: 4px;
}
#{{ id }}-particle .dropdown-toggle-split:not(:focus-visible) { box-shadow: none; }
#{{ offcanvas_id }} { position: fixed; overflow-x: hidden; }
#{{ offcanvas_id }} .nav-link { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
#{{ offcanvas_id }} .d-flex > .nav-link { min-width: 0; }
#{{ offcanvas_id }} .oc-close-btn { opacity: 0.8; }
#{{ offcanvas_id }} .oc-close-btn:hover { opacity: 1; }
{% if r_social_color %}
#{{ id }}-particle .g-nav-social .nav-link { color: {{ r_social_color|e }}; }
#{{ offcanvas_id }} .g-nav-social .nav-link { color: {{ r_social_color|e }}; }
{% endif %}
{% if r_color or r_hover_color or r_dropdown_bg or r_dd_hover_bg or r_dd_hover_color %}
#{{ id }}-particle .dropdown-menu {
{% if r_dropdown_bg %}    --bs-dropdown-bg: {{ r_dropdown_bg|e }};
{% endif %}
{% if r_color %}    --bs-dropdown-color: {{ r_color|e }};
    --bs-dropdown-link-color: {{ r_color|e }};
{% endif %}
{% if r_hover_color or r_dd_hover_color %}    --bs-dropdown-link-hover-color: {{ (r_dd_hover_color ?: r_hover_color)|e }};
    --bs-dropdown-link-active-color: {{ (r_dd_hover_color ?: r_hover_color)|e }};
{% endif %}
    --bs-dropdown-link-hover-bg: {{ r_dd_hover_bg ?: 'transparent' }};
    --bs-dropdown-link-active-bg: {{ r_dd_hover_bg ?: 'transparent' }};
}
{% endif %}
{# Nadpisanie starego selektora Helium SCSS (Bootstrap 3) — tylko gdy user jawnie ustawił kolor.
   Bez tego Helium kompiluje Accent Color 2 jako stały background: #8f4dae na hover. #}
{% if r_dd_hover_bg %}
#{{ id }}-particle .dropdown-menu > li > a:hover,
#{{ id }}-particle .dropdown-menu > li > a:focus,
#{{ id }}-particle .dropdown-submenu:hover > a,
#{{ id }}-particle .dropdown-submenu:focus > a {
    background: {{ r_dd_hover_bg|e }} !important;
{% if r_dd_hover_color or r_hover_color %}    color: {{ (r_dd_hover_color ?: r_hover_color)|e }} !important;
{% endif %}
}
