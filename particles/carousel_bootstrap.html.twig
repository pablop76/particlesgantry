{% extends '@nucleus/partials/particle.html.twig' %}

{# ══════════════════════════════════════════════════════════════
   ZMIENNE GLOBALNE — dostępne we wszystkich blokach
   ══════════════════════════════════════════════════════════════ #}

{% set carousel_id = 'bs-carousel-' ~ id %}

{# Filtruj ukryte slajdy #}
{% set active_items = [] %}
{% for item in particle.items|default([]) %}
    {% if not item.disable %}
        {% set active_items = active_items|merge([item]) %}
    {% endif %}
{% endfor %}

{# Opcje karuzeli #}
{% set transition    = particle.transition|default('slide') %}
{% set show_controls  = particle.controls|default('show') != 'hide' %}
{% set indicators     = particle.indicators|default('dots') %}
{% set dark_theme     = particle.dark_theme %}
{% set height         = particle.height|default('') %}
{% set height_mobile  = particle.height_mobile|default('') %}
{% set extra_class    = particle.class|default('') %}

{# Overlay — ustawienia globalne #}
{% set overlay_color   = particle.overlay_color|default('') %}
{% set overlay_opacity = particle.overlay_opacity|default('') %}

{# Caption — ustawienia globalne #}
{% set caption_pos    = particle.caption_position|default('bottom-center') %}
{% set caption_align  = particle.caption_text_align|default('center') %}
{% set cap_bg_color   = particle.caption_bg_color|default('') %}
{% set cap_bg_blur    = particle.caption_bg_blur|default('0') %}
{% set cap_radius         = particle.caption_border_radius|default('0') %}
{% set title_tag          = particle.caption_title_tag|default('h2') %}
{% set cap_btn_radius     = particle.caption_btn_border_radius|default('') %}
{% set cap_bdr_width      = particle.caption_border_width|default('') %}
{% set cap_bdr_style      = particle.caption_border_style|default('solid') %}
{% set cap_bdr_color      = particle.caption_border_color|default('') %}
{% set cap_bdr_opacity    = particle.caption_border_opacity|default('1') %}

{# Szerokość i padding caption #}
{% set cap_width           = particle.caption_width|default('100%') %}
{% set cap_max_width       = particle.caption_max_width|default('') %}
{% set cap_padding         = particle.caption_padding|default('1.25rem 1.5rem') %}
{% set cap_wrapper_padding = particle.caption_wrapper_padding|default('1.5rem') %}

{# 9-punktowa pozycja caption → align-items (pionowo) + justify-content (poziomo) #}
{% set cap_valign_map = {
    'top-start'    : 'flex-start', 'top-center'    : 'flex-start', 'top-end'    : 'flex-start',
    'middle-start' : 'center',     'middle-center'  : 'center',    'middle-end' : 'center',
    'bottom-start' : 'flex-end',   'bottom-center'  : 'flex-end',  'bottom-end' : 'flex-end'
} %}
{% set cap_halign_map = {
    'top-start'    : 'flex-start', 'middle-start'  : 'flex-start', 'bottom-start'  : 'flex-start',
    'top-center'   : 'center',     'middle-center' : 'center',     'bottom-center' : 'center',
    'top-end'      : 'flex-end',   'middle-end'    : 'flex-end',   'bottom-end'    : 'flex-end'
} %}
{% set cap_valign = cap_valign_map[caption_pos]|default('flex-end') %}
{% set cap_halign = cap_halign_map[caption_pos]|default('center') %}

{# Wyrównanie tekstu i przycisków wewnątrz caption #}
{% set btn_justify_map = {
    'start'  : 'flex-start',
    'center' : 'center',
    'end'    : 'flex-end'
} %}
{% set btn_justify = btn_justify_map[caption_align]|default('center') %}



{# ══════════════════════════════════════════════════════════════
   CSS
   ══════════════════════════════════════════════════════════════ #}
{% block stylesheets %}
{% if particle.enabled and active_items|length > 0 %}
<script>(function(){if(document.head.querySelector('link[href*="bootstrap.min.css"]'))return;var l=document.createElement('link');l.rel='stylesheet';l.href='{{ gantry.siteUrl() }}media/vendor/bootstrap/css/bootstrap.min.css';document.head.appendChild(l);}());</script>
<style>
/* ── Kontener slajdu ── */
#{{ carousel_id }} .carousel-item {
    position: relative;
    overflow: hidden;{% if height %}
    height: {{ height|e }};{% endif %}
}
{% if height %}
#{{ carousel_id }} .carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
{% endif %}
{% if height_mobile %}
@media (max-width: 767px) {
    #{{ carousel_id }} .carousel-item {
        height: {{ height_mobile|e }};
    }
    #{{ carousel_id }} .carousel-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
}
{% endif %}

/* ── Overlay (nakładka) ── */
#{{ carousel_id }} .carousel-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
}

/* ── Wrapper pozycjonujący caption ── */
#{{ carousel_id }} .caption-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: {{ cap_valign }};
    justify-content: {{ cap_halign }};
    padding: {{ cap_wrapper_padding|e }};
    pointer-events: none;
}

/* ── Tło + blur caption — wzorzec glassmorphism ── */
{% if cap_bg_color %}
#{{ carousel_id }} { --cap-bg-color: {{ cap_bg_color|e }}; }
{% endif %}
#{{ carousel_id }} .caption-inner {
    position: relative;
    width: {{ cap_width|e }};
    {% if cap_max_width %}max-width: {{ cap_max_width|e }};{% else %}max-width: 100%;{% endif %}
    overflow: hidden;
    border-radius: {{ cap_radius ?: '0' }};
    padding: {{ cap_padding|e }};
    text-align: {{ caption_align|e }};
    pointer-events: auto;
    isolation: isolate;{% if cap_bg_color %}
    background: var(--cap-bg-color);{% endif %}{% if cap_bg_blur and cap_bg_blur|trim != '0' %}
    backdrop-filter: blur({{ cap_bg_blur|e }}px);
    -webkit-backdrop-filter: blur({{ cap_bg_blur|e }}px);{% endif %}{% if cap_bdr_width and cap_bdr_color %}
    border: {{ cap_bdr_width|e }} {{ cap_bdr_style|e }} {{ cap_bdr_color|e }};{% endif %}
}


#{{ carousel_id }} .caption-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: {{ btn_justify }};
}

{% if cap_btn_radius %}
/* ── Zaokrąglenie przycisków ── */
#{{ carousel_id }} .caption-buttons .btn {
    border-radius: {{ cap_btn_radius|e }};
}
{% endif %}

/* ── Animacje przycisków ── */
{% set b1_anim = particle.btn1_animation|default('none') %}
{% set b2_anim = particle.btn2_animation|default('none') %}
{% if b1_anim == 'pulse' or b2_anim == 'pulse' %}
@keyframes cbp-pulse {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.06); }
}
#{{ carousel_id }} .btn-anim-pulse {
    animation: cbp-pulse 1.8s ease-in-out infinite;
}
{% endif %}
{% if b1_anim == 'bounce' or b2_anim == 'bounce' %}
@keyframes cbp-bounce {
    0%, 100% { transform: translateY(0); }
    40%      { transform: translateY(-8px); }
    70%      { transform: translateY(-4px); }
}
#{{ carousel_id }} .btn-anim-bounce:hover {
    animation: cbp-bounce 0.45s ease;
}
{% endif %}
{% if b1_anim == 'shake' or b2_anim == 'shake' %}
@keyframes cbp-shake {
    0%, 100% { transform: translateX(0); }
    20%      { transform: translateX(-5px); }
    40%      { transform: translateX(5px); }
    60%      { transform: translateX(-3px); }
    80%      { transform: translateX(3px); }
}
#{{ carousel_id }} .btn-anim-shake:hover {
    animation: cbp-shake 0.4s ease;
}
{% endif %}
{% if b1_anim == 'glow' or b2_anim == 'glow' %}
#{{ carousel_id }} .btn-anim-glow {
    transition: box-shadow 0.3s ease;
}
#{{ carousel_id }} .btn-anim-glow:hover {
    box-shadow: 0 0 14px 4px rgba(255, 255, 255, 0.45);
}
{% endif %}
{% if b1_anim == 'lift' or b2_anim == 'lift' %}
#{{ carousel_id }} .btn-anim-lift {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
}
#{{ carousel_id }} .btn-anim-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
}
{% endif %}
{% if b1_anim == 'icon-slide' or b2_anim == 'icon-slide' %}
#{{ carousel_id }} .btn-anim-icon-slide .btn-icon-left,
#{{ carousel_id }} .btn-anim-icon-slide .btn-icon-right {
    display: inline-block;
    transition: transform 0.25s ease;
}
#{{ carousel_id }} .btn-anim-icon-slide:hover .btn-icon-left  { transform: translateX(-4px); }
#{{ carousel_id }} .btn-anim-icon-slide:hover .btn-icon-right { transform: translateX(4px); }
{% endif %}

/* ── Wskaźniki numeryczne ── */
{% if indicators == 'numbers' %}
#{{ carousel_id }} .carousel-indicators [data-bs-slide-to] {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 2rem;
    text-indent: 0;
    border-top: none;
    border-bottom: none;
    background-clip: unset;
    border: 2px solid rgba(255,255,255,0.6);
    background-color: rgba(255,255,255,0.15);
}
#{{ carousel_id }} .carousel-indicators [data-bs-slide-to].active {
    background-color: rgba(255,255,255,0.9);
    color: #000;
}
{% endif %}
</style>
{% endif %}
{% endblock %}


{# ══════════════════════════════════════════════════════════════
   MAKRO — ikona przycisku (FA lub własny obraz)
   ══════════════════════════════════════════════════════════════ #}
{% macro btn_icon(fa_class, img_src, img_size, side) %}
    {%- if img_src -%}
        {%- set sz = img_size ?: '1em' -%}
        <img src="{{ url(img_src)|e }}" class="btn-icon-{{ side }}" width="{{ sz|e }}" height="{{ sz|e }}" alt="" aria-hidden="true" style="vertical-align:middle">
    {%- elseif fa_class -%}
        <i class="{{ fa_class|e }} btn-icon-{{ side }}" aria-hidden="true"></i>
    {%- endif %}
{% endmacro %}

{# ══════════════════════════════════════════════════════════════
   HTML
   ══════════════════════════════════════════════════════════════ #}
{% block particle %}
{% if particle.enabled and active_items|length > 0 %}

{% set carousel_classes = [
    'carousel',
    transition == 'fade' ? 'carousel-fade' : '',
    extra_class
]|filter(v => v)|join(' ')|trim %}

<div id="{{ carousel_id }}"
     class="{{ carousel_classes }}"
     {% if dark_theme %}data-bs-theme="dark"{% endif %}
     {% if particle.autoplay != 'disable' %}data-bs-ride="{{ particle.autoplay == 'carousel' ? 'carousel' : 'true' }}"{% endif %}>

    {# ── Wskaźniki slajdów ── #}
    {% if indicators != 'none' and active_items|length > 1 %}
    <div class="carousel-indicators">
        {% for item in active_items %}
        <button type="button"
                data-bs-target="#{{ carousel_id }}"
                data-bs-slide-to="{{ loop.index0 }}"
                {% if loop.first %}class="active" aria-current="true"{% endif %}
                aria-label="Slajd {{ loop.index }}">{% if indicators == 'numbers' %}{{ loop.index }}{% endif %}</button>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Slajdy ── #}
    <div class="carousel-inner">
        {% for item in active_items %}

        <div class="carousel-item{% if loop.first %} active{% endif %}"
             {% if item.interval %}data-bs-interval="{{ item.interval|e }}"{% endif %}
             {% if item.bg_color %}style="--cap-bg-color:{{ item.bg_color|e }}"{% endif %}>

            {# Obraz tła slajdu #}
            {% if item.image %}
            <picture>
                {% if item.image_mobile %}
                <source media="(max-width: 767px)" srcset="{{ url(item.image_mobile)|e }}">
                {% endif %}
                <img src="{{ url(item.image)|e }}"
                     class="d-block w-100"
                     alt="{{ item.image_alt|default(item.title)|e }}"
                     {% if loop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
                     decoding="async">
            </picture>
            {% endif %}

            {# Overlay — nakładka kolorowa na obraz #}
            {% set slide_ov_color   = item.overlay_color is not empty ? item.overlay_color : overlay_color %}
            {% set slide_ov_opacity = item.overlay_opacity is not empty ? item.overlay_opacity : overlay_opacity %}
            {% if slide_ov_color %}
            <div class="carousel-overlay" style="background-color:{{ slide_ov_color|e }}{% if slide_ov_opacity is not empty %};opacity:{{ slide_ov_opacity|e }}{% endif %}"></div>
            {% endif %}

            {# Caption — renderuj tylko gdy jest jakakolwiek treść #}
            {% set has_buttons = particle.btn1_text or particle.btn2_text %}
            {% if item.subtitle or item.title or item.text or has_buttons %}
            <div class="caption-wrapper">
                <div class="caption-inner">
                    {% set html_ok = item.allow_html %}
                    <div class="caption-content">
                        {% if item.subtitle %}
                        <p class="caption-subtitle"{% if item.subtitle_color %} style="color:{{ item.subtitle_color|e }}"{% endif %}>{{ html_ok ? item.subtitle|raw : item.subtitle|e }}</p>
                        {% endif %}

                        {% if item.title or item.title2 %}
                        <{{ title_tag }} class="caption-title">
                            {%- if item.title -%}
                            <span{% if item.title_color %} style="color:{{ item.title_color|e }}"{% endif %}>{{ html_ok ? item.title|raw : item.title|e }}</span>
                            {%- endif -%}
                            {%- if item.title2 -%}
                            <span{% if item.title2_color %} style="color:{{ item.title2_color|e }}"{% endif %}>{{ html_ok ? item.title2|raw : item.title2|e }}</span>
                            {%- endif -%}
                        </{{ title_tag }}>
                        {% endif %}

                        {% if item.text %}
                        {% if html_ok %}<div class="caption-text">{{ item.text|raw }}</div>
                        {% else %}<p class="caption-text">{{ item.text|e }}</p>{% endif %}
                        {% endif %}

                        {% if has_buttons %}
                        <div class="caption-buttons">
                            {% if particle.btn1_text %}
                            {% set b1_icon     = particle.btn1_icon|default('') %}
                            {% set b1_icon_img = particle.btn1_icon_img|default('') %}
                            {% set b1_icon_sz  = particle.btn1_icon_img_size|default('') %}
                            {% set b1_has_icon = b1_icon or b1_icon_img %}
                            {% set b1_pos      = particle.btn1_icon_pos|default('right') %}
                            {% set b1_anim     = particle.btn1_animation|default('none') %}
                            {% set b1_tt       = particle.btn1_text_transform|default('none') %}
                            {% set b1_styles = [] %}
                            {% if particle.btn1_bg_color     %}{% set b1_styles = b1_styles|merge(['background-color:' ~ particle.btn1_bg_color|e ~ ';border-color:' ~ particle.btn1_bg_color|e]) %}{% endif %}
                            {% if particle.btn1_border_color %}{% set b1_styles = b1_styles|merge(['border-color:' ~ particle.btn1_border_color|e]) %}{% endif %}
                            {% if particle.btn1_border_width %}{% set b1_styles = b1_styles|merge(['border-width:' ~ particle.btn1_border_width|e ~ ';border-style:' ~ (particle.btn1_border_style|default('solid')|e)]) %}{% endif %}
                            {% if particle.btn1_text_color   %}{% set b1_styles = b1_styles|merge(['color:' ~ particle.btn1_text_color|e]) %}{% endif %}
                            {% if b1_tt                      %}{% set b1_styles = b1_styles|merge(['text-transform:' ~ b1_tt|e]) %}{% endif %}
                            {% set b1_classes = ['btn', particle.btn1_style|default('btn-primary')]
                                |merge(b1_anim != 'none' ? ['btn-anim-' ~ b1_anim] : [])
                                |join(' ') %}
                            <a href="{{ particle.btn1_url|default('#')|e }}"
                               class="{{ b1_classes|e }}"
                               {% if b1_styles %}style="{{ b1_styles|join(';')|e }}"{% endif %}
                               {% if particle.btn1_target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}
                               {% if b1_pos == 'only' %}aria-label="{{ particle.btn1_text|e }}"{% endif %}>
                                {%- if b1_has_icon and b1_pos == 'left' -%}{{ _self.btn_icon(b1_icon, b1_icon_img, b1_icon_sz, 'left') }} {% endif -%}
                                {%- if b1_pos != 'only' -%}{{ particle.btn1_text|e }}{%- endif -%}
                                {%- if b1_has_icon and b1_pos in ['right', 'only'] %} {{ _self.btn_icon(b1_icon, b1_icon_img, b1_icon_sz, 'right') }}{%- endif -%}
                            </a>
                            {% endif %}
                            {% if particle.btn2_text %}
                            {% set b2_icon     = particle.btn2_icon|default('') %}
                            {% set b2_icon_img = particle.btn2_icon_img|default('') %}
                            {% set b2_icon_sz  = particle.btn2_icon_img_size|default('') %}
                            {% set b2_has_icon = b2_icon or b2_icon_img %}
                            {% set b2_pos      = particle.btn2_icon_pos|default('right') %}
                            {% set b2_anim     = particle.btn2_animation|default('none') %}
                            {% set b2_tt       = particle.btn2_text_transform|default('none') %}
                            {% set b2_styles = [] %}
                            {% if particle.btn2_bg_color     %}{% set b2_styles = b2_styles|merge(['background-color:' ~ particle.btn2_bg_color|e ~ ';border-color:' ~ particle.btn2_bg_color|e]) %}{% endif %}
                            {% if particle.btn2_border_color %}{% set b2_styles = b2_styles|merge(['border-color:' ~ particle.btn2_border_color|e]) %}{% endif %}
                            {% if particle.btn2_border_width %}{% set b2_styles = b2_styles|merge(['border-width:' ~ particle.btn2_border_width|e ~ ';border-style:' ~ (particle.btn2_border_style|default('solid')|e)]) %}{% endif %}
                            {% if particle.btn2_text_color   %}{% set b2_styles = b2_styles|merge(['color:' ~ particle.btn2_text_color|e]) %}{% endif %}
                            {% if b2_tt                      %}{% set b2_styles = b2_styles|merge(['text-transform:' ~ b2_tt|e]) %}{% endif %}
                            {% set b2_classes = ['btn', particle.btn2_style|default('btn-outline-light')]
                                |merge(b2_anim != 'none' ? ['btn-anim-' ~ b2_anim] : [])
                                |join(' ') %}
                            <a href="{{ particle.btn2_url|default('#')|e }}"
                               class="{{ b2_classes|e }}"
                               {% if b2_styles %}style="{{ b2_styles|join(';')|e }}"{% endif %}
                               {% if particle.btn2_target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}
                               {% if b2_pos == 'only' %}aria-label="{{ particle.btn2_text|e }}"{% endif %}>
                                {%- if b2_has_icon and b2_pos == 'left' -%}{{ _self.btn_icon(b2_icon, b2_icon_img, b2_icon_sz, 'left') }} {% endif -%}
                                {%- if b2_pos != 'only' -%}{{ particle.btn2_text|e }}{%- endif -%}
                                {%- if b2_has_icon and b2_pos in ['right', 'only'] %} {{ _self.btn_icon(b2_icon, b2_icon_img, b2_icon_sz, 'right') }}{%- endif -%}
                            </a>
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>

                </div>
            </div>
            {% endif %}

        </div>
        {% endfor %}
    </div>

    {# ── Strzałki nawigacji ── #}
    {% if show_controls and active_items|length > 1 %}
    <button class="carousel-control-prev" type="button"
            data-bs-target="#{{ carousel_id }}" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Poprzedni</span>
    </button>
    <button class="carousel-control-next" type="button"
            data-bs-target="#{{ carousel_id }}" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Następny</span>
    </button>
    {% endif %}

</div>
{% endif %}
{% endblock %}


{# ══════════════════════════════════════════════════════════════
   JS — Bootstrap Carousel
   ══════════════════════════════════════════════════════════════ #}
{% block javascript_footer %}
{% if particle.enabled and active_items|length > 0 %}
<script>
(function () {
    var root = (typeof Joomla !== 'undefined' && Joomla.getOptions)
        ? (Joomla.getOptions('system.paths') || {}).root || ''
        : '';

    import(root + '/media/vendor/bootstrap/js/carousel.min.js').then(function (module) {
        var Carousel = module.C || module.Carousel || module.default;
        var el = document.getElementById('{{ carousel_id }}');
        if (!el || !Carousel) return;

        new Carousel(el, {
            interval : {{ particle.autoplay != 'disable' ? (particle.interval|default('5000')) : 'false' }},
            ride     : {{ particle.autoplay == 'carousel' ? '"carousel"' : (particle.autoplay == 'interaction' ? 'true' : 'false') }},
            touch    : {{ particle.touch|default('enable') != 'disable' ? 'true' : 'false' }},
            wrap     : {{ particle.wrap|default('enable') != 'disable' ? 'true' : 'false' }},
            keyboard : {{ particle.keyboard|default('enable') != 'disable' ? 'true' : 'false' }},
            pause    : {{ particle.pause_hover|default('enable') != 'disable' ? '"hover"' : 'false' }}
        });
    }).catch(function (err) {
        console.warn('[Carousel Bootstrap] Błąd ładowania JS:', err);
    });
}());
</script>
{% endif %}
{% endblock %}
